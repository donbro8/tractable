# Copy this file to .env and fill in values before running docker compose
# Never commit .env — it is listed in .gitignore

# PostgreSQL
POSTGRES_USER=tractable
POSTGRES_PASSWORD=tractable_password_here
POSTGRES_DB=tractable
# Async SQLAlchemy URL — used by Alembic and AgentStateStore
DATABASE_URL=postgresql+asyncpg://tractable:tractable_password_here@localhost:5433/tractable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# FalkorDB (host Redis-compatible port)
FALKORDB_HOST=localhost
FALKORDB_PORT=6380

# GitHub — use a personal access token with repo + webhook scopes
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=<your-github-personal-access-token>

# Anthropic — used by the agent runtime for LLM calls
ANTHROPIC_API_KEY=sk-ant-your_api_key_here

# Copy this file to .env and fill in values before running docker compose
# Never commit .env — it is listed in .gitignore

# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# GitHub
GITHUB_TOKEN=

# Anthropic
ANTHROPIC_API_KEY=

# FalkorDB (host Redis-compatible port)
FALKORDB_HOST=localhost
FALKORDB_PORT=6380

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
